{
  "language": "rust",
  "lift": {
    "scalars": {
      "i8": "Int",
      "i16": "Int",
      "i32": "Int",
      "i64": "Int",
      "isize": "Int",
      "u8": "Int",
      "u16": "Int",
      "u32": "Int",
      "u64": "Int",
      "usize": "Int",
      "f32": "Float",
      "f64": "Float",
      "bool": "Bool",
      "String": "String",
      "str": "String"
    },
    "type_wraps": [],
    "rule_lifts": {
      "EnumDecl": "IREnum",
      "StructDecl": "IRStruct",
      "FnDecl": "IRFn",
      "Field": "IRStructField",
      "Param": "IRParam",
      "TypeAliasDecl": "IRTypeAlias"
    },
    "body_delimiters": [
      "{",
      "}"
    ],
    "structural_rules": {}
  },
  "lower": {
    "scalars": {
      "String": "String",
      "Float": "f64",
      "Int": "i64",
      "Bool": "bool",
      "Unit": "()"
    },
    "type_wraps": [],
    "comment_prefix": "// ",
    "preamble_template": "{{comment_prefix}}AUTO-GENERATED via `indexion kgf transcribe`: {{source_lang}} -> {{target_lang}}\n{{comment_prefix}}STUB \u2014 function bodies are CONVERSION-class gaps; structure is mechanical.\n\n",
    "no_template_template": "{{comment_prefix}}{{unresolved_marker}}no_template for rule={{rule}}\n",
    "emit_templates": {
      "IRTypeAlias": "pub type {{id_text}} = {{rhs}};\n",
      "IREnum": "pub enum {{id_text}} {\n    {{variants}}\n}\n",
      "IRStruct": "pub struct {{id_text}} {\n    {{fields}},\n}\n",
      "IRStructField": "pub {{id_text}}: {{type}}",
      "IRFn": "pub fn {{id_text}}({{params}}) -> {{return}} {{body_text}}\n",
      "IRParam": "{{id_text}}: {{type}}",
      "IRImport": "// import {{from_text}}\n"
    },
    "emit_order": [
      "IRTypeAlias",
      "IREnum",
      "IRStruct",
      "IRFn"
    ],
    "text_replace_pairs": [
      {
        "open": "Optional<",
        "close": ">",
        "template": "Option<%s>"
      },
      {
        "open": "Array<",
        "close": ">",
        "template": "Vec<%s>"
      }
    ],
    "collect_separators": {
      "fields": ",\n    ",
      "params": ", ",
      "variants": ",\n    "
    },
    "regex_replace": [
      { "pattern": ":\\s*\\([^)]*\\)\\s*=>\\s*[A-Za-z_][A-Za-z0-9_]*", "replacement": ": fn(Todo) -> bool" }
    ]
  }
}
